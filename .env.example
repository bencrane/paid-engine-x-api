# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ClickHouse
CLICKHOUSE_HOST=gf9xtjjqyl.us-east-1.aws.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=paid_edge

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://your-app.com/auth/linkedin/callback
LINKEDIN_API_VERSION=202603

# App
APP_ENV=development
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# Anthropic (set in Doppler — injected via `doppler run` in production)
# For local dev without Doppler, set directly:
ANTHROPIC_API_KEY=

# Doppler (set in Railway, not locally)
# DOPPLER_TOKEN_BACKEND_API=
